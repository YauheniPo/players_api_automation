root = true

# ── Universal ─────────────────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# ── Kotlin & Gradle Kotlin DSL ────────────────────────────────────────────────
[*.{kt,kts}]
indent_style = space
indent_size  = 4
max_line_length = 120

# ── ktlint standard ruleset ───────────────────────────────────────────────────
# All standard rules are enabled by default; below we explicitly tune each one.

# Imports
ktlint_standard_no-wildcard-imports         = enabled   # import org.foo.* → forbidden
ktlint_standard_no-unused-imports           = enabled   # remove dead imports on save
ktlint_standard_import-ordering             = enabled   # ascii order, no blank lines between same group

# Blank lines
ktlint_standard_no-consecutive-blank-lines  = enabled   # max 1 blank line between declarations
ktlint_standard_no-blank-line-before-rbrace = enabled   # no blank line before closing }
ktlint_standard_no-empty-first-line-in-class-body = enabled

# Trailing commas — consistent with Kotlin style guide & cleaner git diffs
ktlint_standard_trailing-comma-on-call-site        = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled

# Braces & spacing
ktlint_standard_brace-style                = enabled   # K&R braces: fun foo() {
ktlint_standard_spacing-around-operators   = enabled   # a + b, not a+b
ktlint_standard_spacing-between-declarations-with-annotations = enabled
ktlint_standard_comment-spacing            = enabled   # // comment, not //comment
ktlint_standard_no-multi-spaces            = enabled   # a  =  b → a = b

# Naming conventions
ktlint_standard_function-naming            = enabled   # camelCase
ktlint_standard_class-naming               = enabled   # PascalCase
ktlint_standard_property-naming            = enabled   # camelCase / SCREAMING_SNAKE for const

# Annotations
ktlint_standard_annotation                 = enabled   # @Ann on its own line if multi-annotation

# String templates
ktlint_standard_string-template            = enabled   # "${x}" → "$x" when possible
ktlint_standard_string-template-indent     = enabled

# Misc
ktlint_standard_no-empty-class-body        = enabled   # class Foo {} → class Foo
ktlint_standard_no-semi                    = enabled   # no semicolons
ktlint_standard_filename                   = enabled   # file name matches top-level class

# ── Rules disabled intentionally ──────────────────────────────────────────────

# RestAssured chains are multi-line by design; wrapping rules break readability:
ktlint_standard_multiline-expression-wrapping = disabled

# Argument list wrapping is too aggressive for SoftAssertions blocks:
ktlint_standard_argument-list-wrapping = disabled

# ── TOML / Properties ─────────────────────────────────────────────────────────
[*.{toml,properties}]
indent_style = space
indent_size  = 2

# ── XML (testng.xml, logback.xml) ─────────────────────────────────────────────
[*.xml]
indent_style = space
indent_size  = 4
